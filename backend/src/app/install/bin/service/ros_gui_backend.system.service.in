[Unit]
Description=ROS GUI Backend
After=network-online.target

[Service]
Type=simple
WorkingDirectory=@ROS_GUI_BACKEND_PREFIX@/bin
ExecStart=@ROS_GUI_BACKEND_PREFIX@/bin/ros_gui_backend --config-json @ROS_GUI_BACKEND_PREFIX@/bin/gui_app_settings.json --port 8080 --document-root @ROS_GUI_BACKEND_PREFIX@/bin/dist
Restart=on-failure
Environment=LD_LIBRARY_PATH=@ROS_GUI_BACKEND_PREFIX@/lib

[Install]
WantedBy=multi-user.target
